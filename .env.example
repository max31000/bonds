# Локальная разработка (docker-compose). Значения ниже — dev-заглушки,
# НЕПРИГОДНЫЕ для прода. Реальные секреты задаются как GitHub Actions
# Secrets/Variables (см. README.md, раздел "Секреты") и как переменные
# окружения контейнера на VDS — никогда не коммитятся в репозиторий.

# Пароль root для локального MySQL-контейнера (docker-compose).
MYSQL_ROOT_PASSWORD=bonds_dev

# Development | Production
ASPNETCORE_ENVIRONMENT=Development

# Frontend (Vite) — базовый путь API и имя Telegram-бота для Login Widget.
# В проде эти значения приходят из GitHub Actions Variables при сборке.
VITE_API_BASE=/bonds/api
VITE_TELEGRAM_BOT_USERNAME=REPLACE_WITH_BOT_USERNAME
